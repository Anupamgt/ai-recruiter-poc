# AI Recruiter PoC — Environment Variables
# Copy to .env and fill in your values

# Google AI API Key (required)
GOOGLE_API_KEY=your-api-key-here

# Model IDs (verified June 2026)
LLM_MODEL_ID=gemini-3.1-pro-preview
EMBEDDING_MODEL_ID=gemini-embedding-2

# Default thinking level for LLM calls: MINIMAL, LOW, MEDIUM, HIGH
DEFAULT_THINKING_LEVEL=LOW

# Qdrant Vector DB
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=candidate_chunks

# SQLite Database (PoC) — swap to postgres:// for production
DATABASE_URL=sqlite+aiosqlite:///./data/recruiter.db

# CV Watch Directory (simulates GCS bucket)
WATCH_DIR=./data/sample_resumes

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Backend host/port
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
